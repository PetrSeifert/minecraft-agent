{
  "name": "minecraft-agent",
  "version": "1.0.0",
  "description": "Modular Minecraft agent starter built on Mineflayer",
  "main": "src/index.ts",
  "scripts": {
    "start": "node --env-file=.env --import tsx src/index.ts",
    "start:example": "node --env-file=.env.example --import tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm test",
    "test": "node --import tsx --test test/**/*.test.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "mineflayer": "^4.35.0",
    "mineflayer-pathfinder": "^2.4.5",
    "vec3": "^0.1.10"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite-plus": "latest"
  },
  "packageManager": "npm@11.12.1",
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  }
}
